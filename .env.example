# Hue bridge
HUE_BRIDGE_IP=192.0.2.10

# Hue light name
HUE_LIGHT_NAME=Your Light Name

# Server port
PORT=7999

# Bind hosts. Binding controls which local network interfaces accept traffic;
# it does not filter client source IPs. Use localhost for local-only access,
# and add a Tailscale hostname/IP when exposing through your tailnet.
SMART_HOME_BIND_HOSTS=127.0.0.1,quantum.tail63c3c5.ts.net

# Optional control token for mutating APIs. When set, physical actions accept
# X-Smart-Home-Token: <token> or Authorization: Bearer <token>.
SMART_HOME_API_TOKEN=replace-with-a-long-random-token

# Optional CORS allowlist for browser clients.
SMART_HOME_CORS_ORIGINS=http://localhost:7999,http://127.0.0.1:7999,http://quantum.tail63c3c5.ts.net:7999,https://quantum.tail63c3c5.ts.net

# Rinnai account
RINNAI_USERNAME=your_email@example.com
RINNAI_PASSWORD=your_password

# Meross account
MEROSS_EMAIL=your_email@example.com
MEROSS_PASSWORD=your_password

# Optional: garage door trigger notification via Resend
# Enabled only when all four values are set and GARAGE_NOTIFY_ENABLED=true.
# GARAGE_NOTIFY_RECIPIENTS supports comma or semicolon separated addresses.
# RESEND_API_KEY may be a resolved key or an op:// 1Password secret reference.
GARAGE_NOTIFY_ENABLED=false
GARAGE_NOTIFY_RECIPIENTS=you@example.com;alerts@example.com
RESEND_API_KEY=op://your-vault/your-item/resend_api_key
RESEND_FROM_EMAIL="Smart Home <notifications@example.com>"

# Amcrest camera credentials
CAMERA_USER=your_camera_user
CAMERA_PASSWORD=your_camera_password
